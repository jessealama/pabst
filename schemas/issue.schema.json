{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://pabst.test/schemas/issue.schema.json",
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "file": {
          "type": "string"
        },
        "function": {
          "$ref": "#/definitions/functionName"
        },
        "property": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "const": "falsified"
        },
        "counterexample": {
          "$ref": "#/definitions/counterexample"
        }
      },
      "required": ["file", "function", "property", "kind", "counterexample"],
      "additionalProperties": false,
      "title": "falsified"
    },
    {
      "type": "object",
      "properties": {
        "file": {
          "type": "string"
        },
        "function": {
          "$ref": "#/definitions/functionName"
        },
        "property": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "const": "threw"
        },
        "counterexample": {
          "$ref": "#/definitions/counterexample"
        },
        "error": {
          "type": "string"
        }
      },
      "required": [
        "file",
        "function",
        "property",
        "kind",
        "counterexample",
        "error"
      ],
      "additionalProperties": false,
      "title": "threw"
    },
    {
      "type": "object",
      "properties": {
        "file": {
          "type": "string"
        },
        "function": {
          "$ref": "#/definitions/functionName"
        },
        "property": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "const": "exhausted"
        },
        "error": {
          "type": "string"
        }
      },
      "required": ["file", "function", "property", "kind", "error"],
      "additionalProperties": false,
      "title": "exhausted"
    }
  ],
  "title": "Pabst Issue",
  "description": "A single property failure emitted by the pabst reporter.",
  "definitions": {
    "functionName": {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*([#.][A-Za-z_][A-Za-z0-9_]*)?$",
      "description": "Bare function name, or Class#method (instance) / Class.method (static)."
    },
    "counterexample": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "anyOf": [
          {
            "type": "number"
          },
          {
            "type": "boolean"
          },
          {
            "type": "string"
          }
        ]
      }
    }
  }
}
