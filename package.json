{
  "name": "pabst",
  "version": "0.0.1",
  "description": "Property-based testing from @ensures annotations, powered by fast-check.",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "pabst": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "default": "./dist/runtime.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "license": "MIT",
  "dependencies": {
    "@fast-check/vitest": "^0.4.1",
    "fast-check": "^4.8.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "ajv": "^8.20.0"
  }
}
