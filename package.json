{
  "name": "@jessealama/pabst",
  "version": "0.8.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Property-based testing from @ensures annotations, powered by fast-check.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jessealama/pabst.git"
  },
  "homepage": "https://github.com/jessealama/pabst#readme",
  "bugs": {
    "url": "https://github.com/jessealama/pabst/issues"
  },
  "keywords": [
    "property-based-testing",
    "fast-check",
    "vitest",
    "jsdoc",
    "ensures",
    "testing"
  ],
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "pabst": "dist/cli.js"
  },
  "exports": {
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "default": "./dist/runtime.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.tests.json",
    "prepublishOnly": "npm run build && npm run typecheck && npm test",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "coverage": "vitest run --coverage",
    "mutation": "stryker run"
  },
  "license": "MIT",
  "dependencies": {
    "@fast-check/vitest": "^0.4.1",
    "fast-check": "^4.8.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.9",
    "ajv": "^8.20.0",
    "prettier": "3.9.4"
  }
}
